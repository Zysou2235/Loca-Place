# --- Database (PostgreSQL) ---
# Use a hosted Postgres: Neon, Supabase, or Vercel Postgres.
# For serverless (Vercel) use the POOLED connection string.
DATABASE_URL="postgresql://user:password@host:5432/eskalebox?sslmode=require"

# --- App base URL (used for QR codes & Stripe redirects) ---
# In production set this to your deployed URL, e.g. https://eskale-box.vercel.app
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Auth ---
# REQUIRED in production. Generate one with: openssl rand -hex 32
SESSION_SECRET="change-me-with-a-long-random-string"

# --- Admin ---
# Emails autorisés à accéder à l'espace /admin (séparés par des virgules).
ADMIN_EMAILS="ton-email@exemple.fr"

# --- Stripe ---
# Seule clé indispensable pour activer paiements + abonnements.
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
# Optionnel (recommandé en prod) : secret du webhook pour fiabiliser la synchro
# des abonnements. Sans lui, l'abonnement s'active quand même au retour de paiement.
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# Les tarifs d'abonnement sont créés automatiquement — aucun Price ID à configurer.

# --- Envoi du code de boîte au voyageur après paiement ---
# Email via Resend (https://resend.com) — clé API + expéditeur (domaine vérifié).
RESEND_API_KEY="re_xxx"
RESEND_FROM="Eskale Box <onboarding@resend.dev>"
# SMS via Twilio (optionnel)
TWILIO_ACCOUNT_SID="ACxxx"
TWILIO_AUTH_TOKEN="xxx"
TWILIO_FROM="+33xxxxxxxxx"

# --- Monitoring d'erreurs (Sentry, optionnel) ---
# Crée un projet Next.js sur https://sentry.io puis colle son DSN ici.
# Sans DSN, le SDK reste inactif (aucun appel réseau, aucun impact).
SENTRY_DSN="https://xxx@xxx.ingest.de.sentry.io/xxx"
# Même valeur que SENTRY_DSN, mais exposée au navigateur (préfixe NEXT_PUBLIC_
# obligatoire pour que Next.js l'embarque côté client).
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.de.sentry.io/xxx"
# Optionnel : permet l'upload des source maps au build pour des stack traces
# lisibles (sinon Sentry reçoit du code minifié). Settings > Auth Tokens sur sentry.io.
SENTRY_ORG="ton-org-sentry"
SENTRY_PROJECT="escale-box"
SENTRY_AUTH_TOKEN="sntrys_xxx"
