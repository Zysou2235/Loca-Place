# --- Database (PostgreSQL) ---
# Use a hosted Postgres: Neon, Supabase, or Vercel Postgres.
# For serverless (Vercel) use the POOLED connection string.
#   Neon:     postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
#   Supabase: postgresql://postgres.xxx:pass@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
#   Vercel:   copy the value of POSTGRES_PRISMA_URL
DATABASE_URL="postgresql://user:password@host:5432/eskalebox?sslmode=require"

# --- App base URL (used for QR codes & Stripe redirects) ---
# In production set this to your deployed URL, e.g. https://eskale-box.vercel.app
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Stripe ---
# Secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
# Publishable key (not strictly required for hosted Checkout, kept for future use)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
