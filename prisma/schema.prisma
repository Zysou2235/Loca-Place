// Escale Box — Host, Box, Product (+ host auth, abonnement, Stripe Connect)
// Database: PostgreSQL (Neon / Supabase / Vercel Postgres) for production on Vercel.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Host {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String? // téléphone (optionnel) — contact + recherche admin
  passwordHash String?
  // Vérifié = email prouvé (connexion Google, ou lien de réinitialisation).
  // L'accès admin EXIGE un email vérifié (empêche de revendiquer un email admin
  // par simple inscription mot de passe).
  emailVerified Boolean @default(false)
  image         String?
  // Incrémenté pour invalider toutes les sessions existantes (ex. après reset
  // du mot de passe). La session signée embarque cette version.
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())

  // Stripe Connect Express account (acct_...) — receives the product sales.
  stripeAccountId String?
  chargesEnabled  Boolean @default(false) // payouts ready (onboarding done)

  // Subscription billing (the platform's revenue).
  stripeCustomerId   String?
  subscriptionStatus String  @default("none") // none | trialing | active | past_due | canceled
  subscriptionPlan   String? // essentiel | duo | multi
  boxQuota           Int     @default(0) // nb de box autorisées par l'abonnement

  // Informations légales / facturation (pour la facture + obligations légales).
  companyName    String?
  siret          String?
  billingLine1   String?
  billingZip     String?
  billingCity    String?
  billingCountry String? @default("France")

  // Adresse de livraison de la box (peut différer de la facturation).
  deliveryName    String?
  deliveryLine1   String?
  deliveryZip     String?
  deliveryCity    String?
  deliveryCountry String? @default("France")

  // Livraison choisie dans le tunnel : transporteur + (si relais) point relais.
  deliveryCarrier    String? // mondial_relay | dpd | chronopost
  deliveryRelayId    String?
  deliveryRelayLabel String?

  // Notes internes (visibles admin uniquement) pour le suivi/support.
  adminNotes String?

  // Compte test (box offertes pendant la phase MVP) : exclu du MRR,
  // géré depuis /admin/test.
  isTestAccount Boolean @default(false)

  boxes    Box[]
  products Product[] // catalogue d'articles réutilisables de l'hôte
}

model Box {
  id        String   @id @default(cuid())
  qrSlug    String   @unique
  name      String
  location  String?
  active    Boolean  @default(true)
  // Lock code set by the platform (admin) before shipping. The box can't sell
  // until a code is set; the code is sent to the traveler after payment.
  accessCode String?
  // Date d'expédition vers l'hôte. Ne peut être posée que si accessCode existe
  // (le code du cadenas ne peut plus être réglé une fois la box partie).
  shippedAt  DateTime?
  // Expédition (Mondial Relay ou manuel) : suivi + URL de l'étiquette prépayée.
  shippingTrackingNumber String?
  shippingLabelUrl       String?
  // Point Relais Mondial Relay choisi par l'hôte (livraison de la box).
  relayId    String? // numéro du Point Relais (ex. "FR-012345")
  relayLabel String? // libellé lisible (nom + ville) pour l'affichage
  createdAt DateTime @default(now())

  hostId String
  host   Host   @relation(fields: [hostId], references: [id], onDelete: Cascade)

  // L'article unique actuellement placé dans la box (choisi dans le catalogue).
  selectedProductId String?
  selectedProduct   Product? @relation("BoxSelected", fields: [selectedProductId], references: [id], onDelete: SetNull)

  orders Order[]
  scans  Scan[]
  leads  Lead[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  currency    String   @default("eur")
  photoUrl    String? // URL https OU image importée (data URL)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  hostId String
  host   Host   @relation(fields: [hostId], references: [id], onDelete: Cascade)

  selectedInBoxes Box[] @relation("BoxSelected")
}

/// Un scan = une visite de la page publique /b/[qrSlug] (QR code flashé).
/// On garde un instantané du produit présenté pour mesurer la conversion même
/// si l'article placé dans la box change ou est supprimé ensuite.
model Scan {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userAgent   String?
  referer     String?
  productId   String? // article présenté au moment du scan (snapshot)
  productName String?
  // Temps passé sur la page voyageur (beacon envoyé à la fermeture).
  durationMs  Int?

  boxId String
  box   Box    @relation(fields: [boxId], references: [id], onDelete: Cascade)

  @@index([boxId, createdAt])
}

/// Email laissé volontairement par un voyageur sur la page publique d'une
/// box (consentement à être recontacté : sondage, offres de la box). Les
/// acheteurs, eux, sont déjà connus via Order.customerEmail — le « Fichier
/// client » admin fusionne les deux sources.
model Lead {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())

  boxId String
  box   Box    @relation(fields: [boxId], references: [id], onDelete: Cascade)

  // Un même email ne compte qu'une fois par box (revisites ignorées).
  @@unique([email, boxId])
}

model Order {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  productName     String
  amountCents     Int
  currency        String   @default("eur")
  customerEmail   String?
  customerPhone   String?
  codeSent        Boolean  @default(false)
  // Moyen de paiement utilisé (card, apple_pay, google_pay, link…) — Stripe.
  paymentMethod   String?
  createdAt       DateTime @default(now())

  boxId String
  box   Box    @relation(fields: [boxId], references: [id], onDelete: Cascade)
}
